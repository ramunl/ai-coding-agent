[Unit]
Description=AI Telegram Coding Agent
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/ai-coding-agent
EnvironmentFile=/opt/ai-coding-agent/.env
ExecStart=/opt/ai-coding-agent/venv/bin/python agent.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
